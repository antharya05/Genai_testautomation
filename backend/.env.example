# LLM Provider: "anthropic" (default) or "groq" (free tier testing)
PROVIDER=groq

# RAG toggle. Default "true" (local dev with full chromadb/sentence-transformers
# stack). Set "false" on resource-constrained hosts (e.g. Render free tier) so
# the heavy ML deps are never imported/downloaded and generation runs without
# retrieval augmentation. Requires requirements-rag.txt installed when true.
RAG_ENABLED=true

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq (alternative free-tier provider)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Database
# Development (default — SQLite, no extra setup required):
# DATABASE_URL=sqlite:///./testgen.db
#
# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/testgen
DATABASE_URL=sqlite:///./testgen.db
